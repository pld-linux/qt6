diff --git a/qttools/src/qdoc/qdoc/tests/validateqdocoutputfiles/testdata/template_sugar/src/template_sugar.cpp b/qttools/src/qdoc/qdoc/tests/validateqdocoutputfiles/testdata/template_sugar/src/template_sugar.cpp
